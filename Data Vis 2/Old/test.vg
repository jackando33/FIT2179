{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "data": {
    "url": "data/australia_choropleth.csv"
  },

  "vconcat": [
    {
      "width": "container",
      "height": 400,

      "title": "Australian Tourism Arrivals",

      "projection": {
        "type": "mercator"
      },

      "layer": [
        {
          "data": {
            "url": "data/states.json",

            "format": {
              "type": "topojson",
              "feature": "states"
            }
          },

          "mark": {
            "type": "geoshape",
            "fill": "lightgray",
            "stroke": "white"
          }
        },

        {
          "transform": [
            {
              "filter": {
                "param": "time_brush"
              }
            }
          ],

          "encoding": {
            "longitude": {
              "field": "longitude",
              "type": "quantitative"
            },

            "latitude": {
              "field": "latitude",
              "type": "quantitative"
            },

            "color": {
              "field": "value",
              "type": "quantitative",
              "title": "Arrivals",
              "scale": {
                "type": "threshold",
                "domain": [50000, 250000, 1000000, 3000000],
                "range": [
                  "#fdbe85",
                  "#fd8d3c",
                  "#e6550d",
                  "#bd0026",
                  "#7f0000"
                ]
              }
            },

            "size": {
              "field": "value",
              "type": "quantitative"
            },

            "tooltip": [
              {
                "field": "date",
                "type": "temporal"
              },

              {
                "field": "value",
                "type": "quantitative"
              },

              {
                "field": "state",
                "type": "nominal"
              }
            ]
          },

          "layer": [
            {
              "mark": {
                "type": "circle",
                "opacity": 0.4
              }
            },

            {
              "transform": [
                {
                  "window": [
                    {
                      "op": "rank",
                      "as": "ranking"
                    }
                  ],

                  "sort": [
                    {
                      "field": "value",
                      "order": "descending"
                    }
                  ]
                },

                {
                  "filter": "datum.ranking == 1"
                },

                {
                  "calculate": "'Highest tourism period; ' + datum['state']",
                  "as": "text_annotation_raw"
                },

                {
                  "calculate": "split(datum.text_annotation_raw,';')",
                  "as": "text_annotation"
                }
              ],

              "mark": {
                "type": "text",
                "align": "right",
                "dx": -8,
                "dy": -8,
                "baseline": "middle",
                "fontStyle": "italic"
              },

              "encoding": {
                "text": {
                  "field": "text_annotation"
                }
              }
            }
          ]
        }
      ]
    },

    {
      "width": "container",
      "height": 60,

      "mark": "line",

      "title": "Use this line chart to filter out the data based on time",

      "params": [
        {
          "name": "time_brush",

          "select": {
            "type": "interval",
            "encodings": ["x"]
          }
        }
      ],

      "encoding": {
        "x": {
          "field": "date",
          "timeUnit": "yearmonth",

          "axis": {
            "title": "",
            "format": "%Y"
          }
        },

        "y": {
          "aggregate": "count",

          "axis": {
            "tickCount": 3,
            "grid": false
          },

          "title": "Count"
        }
      }
    },

    {
      "width": "container",

      "transform": [
        {
          "bin": {
            "maxbins": 5
          },

          "field": "value",

          "as": "arrivals"
        }
      ],

      "mark": "area",

      "encoding": {
        "x": {
          "field": "date",
          "timeUnit": "yearmonth",

          "scale": {
            "domain": {
              "param": "time_brush"
            }
          },

          "axis": {
            "title": "",
            "tickCount": 5,
            "grid": false
          }
        },

        "y": {
          "aggregate": "count",
          "title": "Count of Arrivals"
        },

        "color": {
          "field": "arrivals",

          "scale": {
            "range": [
              "#fdbe85",
              "#fd8d3c",
              "#e6550d",
              "#bd0026",
              "#7f0000"
            ]
          },

          "legend": null
        }
      }
    }
  ],

  "config": {
    "title": {
      "font": "sans-serif",
      "fontSize": 14
    }
  }
}